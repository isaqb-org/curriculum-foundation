# exclude .gitignore, CI config and similar from the generated tarball
.git*           export-ignore

# Force LF on files the Linux container sources/runs. CRLF here = `\r: not found`.
build.config        text eol=lf
curriculum-build.sh text eol=lf
*.adoc              text eol=lf
# Windows launcher keeps CRLF.
curriculum-build.bat text eol=crlf
